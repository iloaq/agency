# Канонический URL для OG/sitemap — один (ниже). Второй домен: 301 на хостинге.
# NEXT_PUBLIC_SITE_URL=https://skybric.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Админка /admin: пароль входа (timing-safe). Приоритет ADMIN_PASSWORD → ADMIN_SECRET → ADMIN_SESSION_SECRET.
# Отдельный ключ подписи cookie (если не задан — берётся тот же пароль/секрет):
# ADMIN_SESSION_SECRET=
ADMIN_PASSWORD=
# или ADMIN_SECRET=

# Серверные INSERT/UPDATE/DELETE в Supabase (обходит RLS). Никогда не префикс NEXT_PUBLIC_.
# Source: https://supabase.com/docs/guides/api/api-keys
SUPABASE_SERVICE_ROLE_KEY=

# Контакты в шапке/меню (если заданы — приоритет над fallback; без опубликованной строки в site_settings).
# NEXT_PUBLIC_SITE_EMAIL=hello@skybric.ru
# NEXT_PUBLIC_SITE_PHONE_DISPLAY=+7(777)336-56-02
# NEXT_PUBLIC_SITE_PHONE_HREF=tel:+77773365602

# Яндекс.Метрика (номер счётчика; по умолчанию в коде 109136066).
# NEXT_PUBLIC_YANDEX_METRIKA_ID=109136066
